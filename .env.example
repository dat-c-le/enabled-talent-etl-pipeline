# ── ACS (Census Bureau) ──────────────────────────────────────────────────────
# Request at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# ── BLS ───────────────────────────────────────────────────────────────────────
# Request at: https://data.bls.gov/registrationEngine/
BLS_API_KEY=your_bls_api_key_here

# ── Google Cloud / BigQuery ───────────────────────────────────────────────────
# Your GCP Project ID (find in Google Cloud Console → project dropdown)
GCP_PROJECT_ID=msba-capstone-498915

# BigQuery dataset name (will be created if it doesn't exist)
BQ_DATASET=disability_employment

# Path to your GCP service account JSON key file (see setup_bigquery.py for instructions)
GCP_CREDENTIALS_PATH=service_account.json
